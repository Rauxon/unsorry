+import Mathlib.Data.Real.Basic
+import Mathlib.Tactic.Linarith
+
+theorem constrained_sum_sq_ge_three (a b c : ℝ) (h : a + b + c = 3) :
+    3 ≤ a ^ 2 + b ^ 2 + c ^ 2 := by
+  nlinarith [sq_nonneg (a - b), sq_nonneg (b - c), sq_nonneg (a - c), h]
