+import Mathlib.Data.Nat.GCD.Basic
+
+theorem coprime_2n1_n1 (n : ℕ) : Nat.Coprime (2 * n + 1) (n + 1) := by
+  have e : 2 * n + 1 = n + (n + 1) := by omega
+  rw [e, Nat.coprime_add_self_left, Nat.coprime_self_add_right]
+  exact Nat.coprime_one_right n
